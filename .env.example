# ===========================================
# QuettaTeaBot Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Discord bot token (required)
# Get yours at: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Groq API key for AI-powered chat summaries (optional)
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=

# API Ninjas key for riddles (optional)
# Get a free key at: https://api-ninjas.com/
API_NINJAS_KEY=

# Custom path for bot data file (optional, defaults to data/bot_data.json)
# BOT_DATA_FILE=/path/to/bot_data.json
